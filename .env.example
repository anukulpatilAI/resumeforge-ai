# Database
DATABASE_URL="postgresql://resumeforge:resumeforge@localhost:5432/resumeforge?schema=public"

# JWT
JWT_SECRET="change-this-in-production-min-32-chars-long"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# AI Provider (ollama | gemini | openrouter)
AI_PROVIDER="ollama"
AI_PROVIDER_FALLBACK="" # optional: second provider to try if primary fails
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="mistralai/mistral-7b-instruct"

# App
PORT=4000
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NODE_ENV="development"
