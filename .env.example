# Database
DATABASE_URL="postgresql://resumeforge:resumeforge@localhost:5432/resumeforge?schema=public"

# JWT
JWT_SECRET="change-this-in-production-min-32-chars-long"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# AI Provider (ollama | gemini | openrouter)
AI_PROVIDER="ollama"
OLLAMA_URL="http://localhost:11434"
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""

# App
PORT=4000
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"
