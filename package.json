{
  "name": "resumeforge-ai",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel --filter @resumeforge/api --filter @resumeforge/web dev",
    "build": "pnpm run -r --if-present build",
    "lint": "pnpm run -r --if-present lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm run -r --if-present clean"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0"
}
